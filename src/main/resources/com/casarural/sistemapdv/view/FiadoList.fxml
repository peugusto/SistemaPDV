<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="500.0" prefWidth="700.0" spacing="0.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.casarural.sistemapdv.controller.FiadoListController">
    <children>
        <HBox alignment="CENTER" style="-fx-background-color: #2c3e50;">
            <children>
                <Label fx:id="labelTitulo" text="Detalhamento de Fiado: [Nome do Cliente]" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
            </children>
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
        </HBox>

        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <TableView fx:id="tableFiados" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="columnData" prefWidth="120" text="Data da Venda" />
                        <TableColumn fx:id="columnVendaId" prefWidth="100" text="Nº Venda" />
                        <TableColumn fx:id="columnValor" prefWidth="120" text="Valor Original" />
                        <TableColumn fx:id="columnStatus" prefWidth="120" text="Status" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-background-color: #ecf0f1; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <Label text="Dívida Total:">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Label fx:id="labelTotalDevendo" text="R$ 0,00" textFill="#c0392b">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>
                        <Button fx:id="btnPagar" onAction="#onPagarAction" prefHeight="40.0" prefWidth="150.0"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                                text="RECEBER PAGAMENTO" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>