<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.casarural.sistemapdv.controller.PDVController">


    <top>
        <HBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <TextField promptText="Código de Barras" fx:id="campoCodigoProduto" prefWidth="200"/>

            <Button text="Adicionar" fx:id="botaoAdicionar" style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </top>


    <center>
        <TableView fx:id="tabelaItens">
            <columns>
                <TableColumn text="Código" fx:id="colunaCodigo" prefWidth="200"/>
                <TableColumn text="Produto" fx:id="colunaProduto" prefWidth="300"/>
                <TableColumn text="Qtd" fx:id="colunaQuantidade" prefWidth="80"/>
                <TableColumn text="Preço" fx:id="colunaPreco" prefWidth="120"/>
                <TableColumn text="Total" fx:id="colunaTotal" prefWidth="120"/>
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>


    <right>
        <VBox spacing="15" prefWidth="300" minWidth="250" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 0 0 0 1;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="RESUMO DA VENDA" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <Separator/>

            <VBox spacing="10" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Subtotal:"/>
                    <Pane HBox.hgrow="ALWAYS" /> <Label fx:id="labelSubtotal" text="R$ 0,00" style="-fx-font-weight: bold;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <Label text="Desconto:"/>
                    <Pane HBox.hgrow="ALWAYS" />
                    <Label fx:id="labelDesconto" text="R$ 0,00" style="-fx-text-fill: red;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <Label text="Total:" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Pane HBox.hgrow="ALWAYS" />
                    <Label fx:id="labelTotal" text="R$ 0,00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: green;"/>
                </HBox>
            </VBox>

            <Separator/>

            <VBox spacing="10">
                <Button text="Finalizar Venda (F1)" fx:id="botaoFinalizar"
                        maxWidth="Infinity" prefHeight="50"
                        style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;"/>

                <Button text="Cancelar Venda (Esc)" fx:id="botaoCancelar"
                        maxWidth="Infinity" prefHeight="40"
                        style="-fx-background-color: #dc3545; -fx-text-fill: white;"/>
            </VBox>
        </VBox>
    </right>



    <bottom>
        <HBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <Button text="Remover Item" fx:id="botaoRemover"/>
            <Button text="Limpar Venda" fx:id="botaoLimpar"/>
        </HBox>
    </bottom>

</BorderPane>

