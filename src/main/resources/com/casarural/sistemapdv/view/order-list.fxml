<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="10.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #27ae60;">
            <children>
                <Label text="Relatório de Produtos Vendidos" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
            </children>
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Início:" style="-fx-font-weight: bold;" />
                        <DatePicker fx:id="dpDataInicio" prefWidth="150.0" />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Fim:" style="-fx-font-weight: bold;" />
                        <DatePicker fx:id="dpDataFim" prefWidth="150.0" />
                    </children>
                </VBox>
                <VBox alignment="BOTTOM_LEFT">
                    <children>
                        <Button fx:id="btnFiltrar" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" 
                                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" 
                                text="Gerar Relatório" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
        </HBox>

        <TableView fx:id="tableViewItens" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="columnCodBarras" prefWidth="120.0" text="Cód. Barras" />
                <TableColumn fx:id="columnProduto" prefWidth="300.0" text="Nome do Produto" />
                <TableColumn fx:id="columnQtdTotal" prefWidth="100.0" text="Qtd. Vendida" />
                <TableColumn fx:id="columnPrecoMedio" prefWidth="120.0" text="Preço Unit. (Médio)" />
                <TableColumn fx:id="columnSubtotal" prefWidth="130.0" text="Total Arrecadado" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-background-color: #ecf0f1;">
            <children>
                <Label text="Faturamento Bruto no Período:">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <Label fx:id="labelFaturamentoTotal" text="R$ 0,00" textFill="#27ae60">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
            </children>
            <padding>
                <Insets bottom="15.0" left="15.0" right="25.0" top="15.0" />
            </padding>
        </HBox>
    </children>
</VBox>